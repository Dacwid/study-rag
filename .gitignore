# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.venv/
venv/
*.egg

# Data — never commit raw files or embeddings
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Environment
.env

# Evaluation results
evaluation/results/*
!evaluation/results/.gitkeep

# OS
.DS_Store
Thumbs.db

# IDE / editor
.vscode/
.idea/
*.swp
*~
*.bak

# uv
uv.lock
.python-version

# Tool caches
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Generated test fixtures (recreated by conftest.py)
tests/fixtures/*.pdf
tests/fixtures/*.pptx
tests/fixtures/*.docx
tests/fixtures/*.md

# Notebooks (exploration only, not part of the system)
notebooks/

# HuggingFace model cache (large, re-downloadable)
.cache/

# Claude / project planning files
CLAUDE.md
RAG_PROJECT_PLAN.md

# Tests
tests/

# Misc generated files
*.log
tmp/
temp/
